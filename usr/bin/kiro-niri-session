#!/bin/sh
#####################################################################
# Author    : Erik Dubois
# Website   : https://kiroproject.be
#####################################################################
#   DO NOT JUST RUN THIS. EXAMINE AND JUDGE. RUN AT YOUR OWN RISK.
#
# Purpose:
#   Session entrypoint for the Kiro niri (noctalia) edition, invoked by
#   kiro-niri.desktop. Points niri at this edition's own config folder
#   (~/.config/kiro-niri/) via NIRI_CONFIG, then hands off to the stock
#   niri-session (which starts niri.service under systemd).
# Why:
#   kiro-niri and kiro-ohmyniri both target niri but ship different
#   configs. Sharing ~/.config/niri/ means switching editions inherits
#   the other one's stale config. A per-edition NIRI_CONFIG folder keeps
#   them cleanly separate. niri-session runs `systemctl --user
#   import-environment`, so the value propagates into niri.service; we
#   also set-environment it directly to be robust against the re-exec.
#####################################################################

NIRI_CONFIG="$HOME/.config/kiro-niri/config.kdl"
export NIRI_CONFIG
systemctl --user set-environment "NIRI_CONFIG=$NIRI_CONFIG" 2>/dev/null || true

exec niri-session "$@"
